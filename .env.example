# Required for GPT-based features (entity extraction, summaries, clustering, quality eval)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_MODEL=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Required for speaker diarization (pyannote.audio models)
HUGGINGFACE_TOKEN=your_token_here

# Optional: Override default pipeline settings
# WHISPER_MODEL_SIZE=large-v2
# WHISPER_LANGUAGE=en
# WHISPER_BATCH_SIZE=32
# WHISPER_VAD_METHOD=pyannote
# WHISPER_VAD_DEVICE=cuda
# DISABLE_GPU=false
